# Copy this file to .env for local development, and set the same variables
# in your Vercel project settings (Settings -> Environment Variables) for
# Production/Preview before deploying.

# Connection string used by the app at runtime. If your provider gives you a
# pooled connection string (e.g. Neon/Vercel Postgres often add "-pooler" to
# the hostname, or provide it as POSTGRES_PRISMA_URL / POSTGRES_URL), use that
# one here.
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Optional: a direct (non-pooled) connection string, used only when running
# migrations ("prisma migrate deploy"/"prisma migrate dev"). Some connection
# poolers reject the DDL statements migrations need. If your provider only
# gives you one connection string, omit this and DATABASE_URL will be used
# for migrations too.
# DIRECT_URL="postgresql://user:password@host:5432/dbname"
