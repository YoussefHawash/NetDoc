// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum DeviceType {
  router
  switch
  firewall
  server
  workstation
  accessPoint
  printer
  other
}

enum DeviceStatus {
  active
  inactive
  maintenance
}

enum LinkType {
  copper
  fiber
  wifi
}

model Site {
  id        String   @id @default(cuid())
  name      String
  address   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subnets   Subnet[]
  devices   Device[]
  staticIps StaticIp[]
  ispIps    IspIp[]
}

model Subnet {
  id          String   @id @default(cuid())
  name        String
  cidr        String
  vlanId      Int?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  siteId String?
  site   Site?   @relation(fields: [siteId], references: [id], onDelete: SetNull)

  devices   Device[]
  staticIps StaticIp[]
}

model StaticIp {
  id         String   @id @default(cuid())
  ipAddress  String
  hostname   String?
  macAddress String?
  assignedTo String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  siteId String?
  site   Site?   @relation(fields: [siteId], references: [id], onDelete: SetNull)

  subnetId String?
  subnet   Subnet? @relation(fields: [subnetId], references: [id], onDelete: SetNull)
}

model IspIp {
  id        String   @id @default(cuid())
  provider  String
  circuitId String?
  ipAddress String
  gateway   String?
  dns       String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  siteId String?
  site   Site?   @relation(fields: [siteId], references: [id], onDelete: SetNull)
}

model Device {
  id             String       @id @default(cuid())
  hostname       String
  ipAddress      String?
  macAddress     String?
  type           DeviceType   @default(other)
  vendor         String?
  model          String?
  serialNumber   String?
  os             String?
  status         DeviceStatus @default(active)
  owner          String?
  notes          String?
  purchaseDate   DateTime?
  warrantyExpiry DateTime?
  positionX      Float        @default(0)
  positionY      Float        @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  siteId String?
  site   Site?   @relation(fields: [siteId], references: [id], onDelete: SetNull)

  subnetId String?
  subnet   Subnet? @relation(fields: [subnetId], references: [id], onDelete: SetNull)

  connectionsA Connection[] @relation("DeviceA")
  connectionsB Connection[] @relation("DeviceB")
}

model Connection {
  id        String   @id @default(cuid())
  portA     String?
  portB     String?
  linkType  LinkType @default(copper)
  label     String?
  createdAt DateTime @default(now())

  deviceAId String
  deviceA   Device @relation("DeviceA", fields: [deviceAId], references: [id], onDelete: Cascade)

  deviceBId String
  deviceB   Device @relation("DeviceB", fields: [deviceBId], references: [id], onDelete: Cascade)
}
