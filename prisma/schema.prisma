// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum DeviceType {
  router
  switch
  firewall
  server
  workstation
  accessPoint
  printer
  other
}

enum DeviceStatus {
  active
  inactive
  maintenance
}

enum LinkType {
  copper
  fiber
  wifi
}

enum VpnTunnelType {
  siteToSite
  remoteAccess
  other
}

model Site {
  id        String   @id @default(cuid())
  name      String
  address   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subnets         Subnet[]
  devices         Device[]
  staticIps       StaticIp[]
  ispIps          IspIp[]
  vlans           Vlan[]
  vpnTunnelsLocal  VpnTunnel[] @relation("VpnLocalSite")
  vpnTunnelsRemote VpnTunnel[] @relation("VpnRemoteSite")
}

model Vlan {
  id        String   @id @default(cuid())
  vlanId    Int
  name      String
  purpose   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  siteId String?
  site   Site?   @relation(fields: [siteId], references: [id], onDelete: SetNull)

  @@unique([siteId, vlanId])
}

model VpnTunnel {
  id             String        @id @default(cuid())
  name           String
  tunnelType     VpnTunnelType @default(siteToSite)
  status         DeviceStatus  @default(active)
  localEndpoint  String?
  remoteEndpoint String?
  encryption     String?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  localSiteId String?
  localSite   Site?   @relation("VpnLocalSite", fields: [localSiteId], references: [id], onDelete: SetNull)

  remoteSiteId String?
  remoteSite   Site?   @relation("VpnRemoteSite", fields: [remoteSiteId], references: [id], onDelete: SetNull)

  deviceId String?
  device   Device? @relation(fields: [deviceId], references: [id], onDelete: SetNull)
}

model Subnet {
  id          String   @id @default(cuid())
  name        String
  cidr        String
  vlanId      Int?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  siteId String?
  site   Site?   @relation(fields: [siteId], references: [id], onDelete: SetNull)

  devices   Device[]
  staticIps StaticIp[]
}

model StaticIp {
  id         String   @id @default(cuid())
  ipAddress  String
  hostname   String?
  macAddress String?
  assignedTo String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  siteId String?
  site   Site?   @relation(fields: [siteId], references: [id], onDelete: SetNull)

  subnetId String?
  subnet   Subnet? @relation(fields: [subnetId], references: [id], onDelete: SetNull)
}

model IspIp {
  id        String   @id @default(cuid())
  provider  String
  circuitId String?
  ipAddress String
  gateway   String?
  dns       String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  siteId String?
  site   Site?   @relation(fields: [siteId], references: [id], onDelete: SetNull)
}

model Vendor {
  id      String   @id @default(cuid())
  name    String   @unique
  devices Device[]
}

model DeviceModel {
  id      String   @id @default(cuid())
  name    String   @unique
  devices Device[]
}

model Device {
  id           String       @id @default(cuid())
  hostname     String
  ipAddress    String?
  macAddress   String?
  type         DeviceType   @default(other)
  serialNumber String?
  status       DeviceStatus @default(active)
  owner        String?
  notes        String?
  portCount    Int          @default(0)
  positionX    Float        @default(0)
  positionY    Float        @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  siteId String?
  site   Site?   @relation(fields: [siteId], references: [id], onDelete: SetNull)

  subnetId String?
  subnet   Subnet? @relation(fields: [subnetId], references: [id], onDelete: SetNull)

  vendorId String?
  vendor   Vendor? @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  deviceModelId String?
  deviceModel   DeviceModel? @relation(fields: [deviceModelId], references: [id], onDelete: SetNull)

  connectionsA Connection[] @relation("DeviceA")
  connectionsB Connection[] @relation("DeviceB")
  vpnTunnels   VpnTunnel[]
}

model Connection {
  id        String   @id @default(cuid())
  portA     String?
  portB     String?
  linkType  LinkType @default(copper)
  label     String?
  createdAt DateTime @default(now())

  deviceAId String
  deviceA   Device @relation("DeviceA", fields: [deviceAId], references: [id], onDelete: Cascade)

  deviceBId String
  deviceB   Device @relation("DeviceB", fields: [deviceBId], references: [id], onDelete: Cascade)
}
